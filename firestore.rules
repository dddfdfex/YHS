// =======================================================
// AURA STUDIO — FIRESTORE SECURITY RULES
// =======================================================
// هذه القواعد تُلصق في: Firebase Console > Firestore Database > Rules
// ملاحظة مهمة: لوحة التحكم في هذا المشروع تستخدم رمز PIN بسيط (0000)
// يُتحقق منه في الواجهة (Client-Side) فقط، وليس عبر Firebase
// Authentication الحقيقي. هذا يعني أن قواعد Firestore هذه لا تستطيع
// تمييز "المدير" عن "الزائر العادي" بثقة كاملة، لأن لا يوجد نظام
// تسجيل دخول حقيقي (Firebase Auth) في الخلفية.
//
// القواعد أدناه تطبّق أقصى تقييد ممكن في ظل هذا التصميم:
// - الزوار العاديون: يمكنهم فقط القراءة وإضافة تفاعلات/طلبات تعديل
//   وتسجيل جلسات، ولا يمكنهم أبداً التعديل أو الحذف.
// - عمليات الإدارة (إضافة/تعديل/حذف الحملات) مفتوحة للكتابة من
//   أي عميل يعرف الـ API key، لأن لا يوجد Firebase Auth حقيقي.
//
// للحصول على حماية فعلية وكاملة بمستوى إنتاج حقيقي، يُنصح بشدة
// بترقية المصادقة لاحقاً إلى Firebase Authentication (مثل تسجيل
// دخول بالبريد/كلمة مرور أو حساب مدير مخصص) بدل PIN ثابت، حتى
// تتمكن هذه القواعد من التحقق بـ request.auth بثقة كاملة.
// =======================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- الحملات ----------
    match /campaigns/{campaignId} {
      // القراءة مسموحة للجميع (المعرض عام)
      allow read: if true;

      // الإنشاء/التعديل/الحذف: مفتوح حالياً (لا يوجد Auth حقيقي للوحة التحكم)
      // عند ترقية المشروع لاستخدام Firebase Auth، استبدل "true" أدناه
      // بشرط مثل: request.auth != null && request.auth.token.admin == true
      allow create, update, delete: if true;
    }

    // ---------- التفاعلات (إعجاب / موافقة) ----------
    match /reactions/{reactionId} {
      allow read: if false;          // لا حاجة لقراءتها مباشرة من الزائر
      allow create: if request.resource.data.keys().hasAll(['campaignId', 'type'])
                    && request.resource.data.type in ['likes', 'approvals'];
      allow update, delete: if false; // لا يمكن تعديل أو حذف التفاعلات
    }

    // ---------- طلبات التعديل ----------
    match /editRequests/{requestId} {
      allow read: if true;  // لوحة التحكم تحتاج قراءتها (بدون Auth حالياً)
      allow create: if request.resource.data.keys().hasAll(['campaignId', 'note'])
                    && request.resource.data.note is string
                    && request.resource.data.note.size() < 2000;
      allow update, delete: if true; // لتحديث الحالة من لوحة التحكم
    }

    // ---------- تتبع المشاهدات ----------
    match /analyticsViews/{viewId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // ---------- الجلسات ----------
    match /sessions/{sessionId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // ---------- سجلات النشاط (تشمل محاولات لقطة الشاشة) ----------
    match /activityLogs/{logId} {
      allow read: if true; // لوحة التحكم تعرضها بدون Auth حقيقي
      allow create: if true;
      allow update, delete: if false; // السجلات لا تُعدَّل أو تُحذف أبداً
    }

    // ---------- محاولات لقطة الشاشة ----------
    match /screenshotAttempts/{attemptId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // ---------- الإعدادات ----------
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
